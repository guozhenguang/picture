        <mxCell id="XyOHrf8oLaBqBv03S7qJ-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;" value="ChangeInfo.mExistenceChanged = true" vertex="1">
